{
  "version": 2,
  "buildCommand": "pnpm -r --filter \"./artifacts/portfolio\" run build",
  "outputDirectory": "artifacts/portfolio/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
