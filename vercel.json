{
  "version": 2,
  "buildCommand": "pnpm -r --filter \"./artifacts/portfolio\" run build",
  "outputDirectory": "artifacts/portfolio/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
